<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.UserMapper">
  <!-- violating: update t_order 缺 user_id 分片键 → 全路由广播 → fw_sharding_key_in_dml fail -->
  <update id="updateStatus">
    update t_order set status=#{s} where id=#{id}
  </update>
  <!-- violating: 业务 DML 直写广播表 t_dict → fw_sharding_broadcast_write fail -->
  <insert id="insertDict">
    insert into t_dict (code, name) values (#{code}, #{name})
  </insert>
  <!-- 含分片键的排序查询：不应触发 fw_sharding_order_merge -->
  <select id="listByUser" resultType="map">
    select * from t_order where user_id=#{uid} order by id
  </select>
</mapper>
